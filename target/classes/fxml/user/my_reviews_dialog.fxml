<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/8.0.171"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.user.MyReviewsDialogController"
      styleClass="dialog-pane"
      prefWidth="550" prefHeight="600">

    <padding>
        <Insets top="30" right="30" left="30" bottom="30"/>
    </padding>

    <Label text="📝 My Reviews &amp; Ratings" styleClass="page-title" style="-fx-font-size: 24px;"/>
    <Label text="Manage your shared experiences" styleClass="page-subtitle"/>

    <ScrollPane fx:id="reviewsScroll" fitToWidth="true" VBox.vgrow="ALWAYS"
                styleClass="content-scroll">
        <VBox fx:id="reviewsContainer" spacing="15">
            <padding>
                <Insets top="10" right="10" left="10" bottom="10"/>
            </padding>
            <!-- Review cards will be added here dynamically -->
        </VBox>
    </ScrollPane>

</VBox>
