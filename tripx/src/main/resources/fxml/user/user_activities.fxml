<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="800.0" prefWidth="1200.0" xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.user.UserActivitiesController"
            stylesheets="/css/style.css, @../../css/user-destinations.css">

    <top>
        <VBox spacing="20" styleClass="header-section">
            <padding>
                <Insets top="30" right="30" left="30" bottom="20"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="20">
                <Button fx:id="backToHomeBtn" text="🏠 Back to Home" styleClass="action-button-secondary"/>
                <VBox>
                    <Label text="✨ Discover Activities" styleClass="page-title"/>
                    <Label text="Unforgettable experiences waiting for you" styleClass="page-subtitle"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="themeBtn" text="🌙" styleClass="theme-toggle-btn"/>
            </HBox>

            <!-- Search and Filter Bar -->
            <HBox spacing="15" alignment="CENTER_LEFT" styleClass="filter-bar">
                <TextField fx:id="searchField" promptText="Search activities or destinations..."
                           HBox.hgrow="ALWAYS" styleClass="search-field"/>

                <ComboBox fx:id="categoryFilter" prefWidth="150" styleClass="filter-combo"
                          promptText="Category"/>

                <Button fx:id="searchBtn" text="🔍 Search" styleClass="action-button"/>
                <Button fx:id="resetBtn" text="🔄 Reset" styleClass="action-button-secondary"/>
            </HBox>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="resultsCountLabel" text="Found 0 activities" styleClass="results-count"/>
                <ProgressIndicator fx:id="loadingIndicator" visible="false" prefWidth="20" prefHeight="20"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="content-scroll">
            <FlowPane fx:id="activitiesContainer"
                      hgap="30" vgap="30"
                      styleClass="destinations-grid">
                <padding>
                    <Insets top="20" right="30" left="30" bottom="30"/>
                </padding>
            </FlowPane>
        </ScrollPane>
    </center>
</BorderPane>
