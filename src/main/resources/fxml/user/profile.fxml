<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0"
            styleClass="profile-root"
            stylesheets="/css/style.css, /css/profile.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.user.ProfileController">

    <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">

        <!-- ═══════════════ LEFT SIDEBAR ═══════════════ -->
        <VBox minWidth="300.0" prefWidth="300.0" prefHeight="800.0"
              styleClass="profile-rail" spacing="0">
            <padding>
                <Insets top="28" right="18" bottom="28" left="18"/>
            </padding>

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-padding: 0 0 22 6;">
                <ImageView fitHeight="36.0" fitWidth="36.0"
                           pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../../images/logo.png"/>
                    </image>
                </ImageView>
                <Label styleClass="rail-logo-text" text="TripX"/>
            </HBox>

            <!-- User Profile Card -->
            <VBox fx:id="sidebarUserProfile" alignment="CENTER" spacing="10"
                  styleClass="sidebar-user-card">
                <StackPane styleClass="sidebar-avatar-circle" alignment="CENTER"
                           fx:id="sidebarAvatarPane">
                    <Label fx:id="sidebarAvatarInitials" styleClass="sidebar-avatar-initials" text="U"/>
                </StackPane>
                <Label fx:id="sidebarUserName" styleClass="sidebar-user-name" text="Loading..."/>
                <Label fx:id="sidebarUserEmail" styleClass="sidebar-user-email" text=""/>
            </VBox>

            <!-- Spacer -->
            <Region prefHeight="18"/>

            <!-- Back button -->
            <Button onAction="#handleBack" styleClass="rail-back-btn" text="← Back to Home"
                    maxWidth="Infinity"/>

            <!-- Spacer -->
            <Region prefHeight="10"/>

            <!-- Section label -->
            <Label styleClass="rail-section-label" text="SETTINGS"
                   style="-fx-padding: 8 6 6 6;"/>

            <!-- Nav Items -->
            <VBox spacing="4">
                <Button fx:id="btnPersonalInfo" maxWidth="Infinity"
                        onAction="#showPersonalInfo"
                        styleClass="rail-item-active"
                        text="👤   Personal Info"/>
                <Button fx:id="btnSecurity" maxWidth="Infinity"
                        onAction="#showAccountSecurity"
                        styleClass="rail-item"
                        text="🔐   Account Security"/>
                <Button fx:id="btnBookings" maxWidth="Infinity"
                        styleClass="rail-item"
                        text="🎫   My Bookings"/>
                <Button fx:id="btnPreferences" maxWidth="Infinity"
                        onAction="#showSearchPreferences"
                        styleClass="rail-item"
                        text="🔍   Search Preferences"/>
                <Button fx:id="btnNotifications" maxWidth="Infinity"
                        onAction="#showUserAnalytics"
                        styleClass="rail-item"
                        text="📊   Your Activity"/>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Footer separator -->
            <Separator styleClass="rail-separator"/>
            <Label style="-fx-text-fill: #CBD5E1; -fx-font-size: 11px; -fx-padding: 8 6 0 6;"
                   text="© 2024 TripX · All rights reserved"/>
        </VBox>

        <!-- ═══════════════ RIGHT CONTENT ═══════════════ -->
        <StackPane fx:id="contentArea" HBox.hgrow="ALWAYS"
                   style="-fx-background-color: #F5F7FA;">
            <padding>
                <Insets bottom="40.0" left="52.0" right="52.0" top="40.0"/>
            </padding>

            <!-- VIEW 1: PERSONAL INFO -->
            <VBox fx:id="personalInfoView" spacing="28" visible="true">

                <VBox spacing="4">
                    <Label styleClass="page-title" text="Personal Info"/>
                    <Label styleClass="page-subtitle"
                           text="Review and update your personal details."/>
                </VBox>

                <ScrollPane fitToWidth="true"
                            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <content>
                        <VBox spacing="24" style="-fx-background-color: transparent;">

                            <!-- Avatar Selection -->
                            <VBox styleClass="content-card">
                                <HBox alignment="CENTER_LEFT" spacing="10"
                                      style="-fx-padding: 0 0 16 0;">
                                    <Label styleClass="card-section-title" text="Choose Avatar"/>
                                    <Label styleClass="card-section-hint"
                                           text="Pick an avatar that represents you"/>
                                </HBox>
                                <ScrollPane fitToHeight="true"
                                            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
                                            vbarPolicy="NEVER">
                                    <content>
                                        <HBox fx:id="avatarContainer" alignment="CENTER_LEFT" spacing="14"/>
                                    </content>
                                </ScrollPane>
                            </VBox>

                            <!-- Personal Details Form -->
                            <VBox spacing="22" styleClass="content-card">
                                <Label styleClass="card-section-title" text="Personal Details"/>

                                <!-- Name Row -->
                                <HBox spacing="24">
                                    <VBox spacing="7" HBox.hgrow="ALWAYS">
                                        <Label styleClass="input-label" text="First Name"/>
                                        <TextField fx:id="firstNameField" promptText="e.g. John"
                                                   styleClass="modern-input"/>
                                        <Label fx:id="firstNameError" styleClass="error-label"
                                               visible="false"/>
                                    </VBox>
                                    <VBox spacing="7" HBox.hgrow="ALWAYS">
                                        <Label styleClass="input-label" text="Last Name"/>
                                        <TextField fx:id="lastNameField" promptText="e.g. Smith"
                                                   styleClass="modern-input"/>
                                        <Label fx:id="lastNameError" styleClass="error-label"
                                               visible="false"/>
                                    </VBox>
                                </HBox>

                                <!-- Email -->
                                <VBox spacing="7">
                                    <Label styleClass="input-label" text="Email Address"/>
                                    <TextField fx:id="emailField" promptText="name@example.com"
                                               styleClass="modern-input"/>
                                    <Label fx:id="emailError" styleClass="error-label"
                                           visible="false"/>
                                    <HBox alignment="CENTER_LEFT" spacing="8">
                                        <Label styleClass="subtitle-label" text="Current:"/>
                                        <Label fx:id="currentEmailLabel" styleClass="value-label"
                                               text=""/>
                                    </HBox>
                                </VBox>

                                <!-- Phone & Gender -->
                                <HBox spacing="24">
                                    <VBox spacing="7" HBox.hgrow="ALWAYS">
                                        <Label styleClass="input-label" text="Phone Number"/>
                                        <TextField fx:id="phoneField" promptText="+216 XX XXX XXX"
                                                   styleClass="modern-input"/>
                                        <Label fx:id="phoneError" styleClass="error-label"
                                               visible="false"/>
                                    </VBox>
                                    <VBox spacing="7" HBox.hgrow="ALWAYS">
                                        <Label styleClass="input-label" text="Gender"/>
                                        <ComboBox fx:id="genderComboBox" maxWidth="Infinity"
                                                  promptText="Select Gender"
                                                  styleClass="modern-input"/>
                                        <Label fx:id="genderError" styleClass="error-label"
                                               visible="false"/>
                                    </VBox>
                                </HBox>

                                <!-- Birth Date -->
                                <VBox spacing="7">
                                    <Label styleClass="input-label" text="Date of Birth"/>
                                    <DatePicker fx:id="birthDatePicker" maxWidth="Infinity"
                                                styleClass="modern-input"/>
                                </VBox>

                                <!-- Save -->
                                <HBox alignment="CENTER_RIGHT" style="-fx-padding: 8 0 0 0;">
                                    <Label fx:id="statusLabel"
                                           style="-fx-padding: 0 18 0 0;" visible="false"/>
                                    <Button fx:id="saveButton" onAction="#handleUpdateProfile"
                                            styleClass="primary-btn" text="Save Changes"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </VBox>

            <!-- VIEW 2: SEARCH PREFERENCES -->
            <VBox fx:id="searchPreferencesView" spacing="28" visible="false">
                <VBox spacing="4">
                    <Label styleClass="page-title" text="Search Preferences"/>
                    <Label styleClass="page-subtitle"
                           text="Customise how TripX recommends content for you."/>
                </VBox>

                <ScrollPane fitToWidth="true"
                            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <content>
                        <VBox spacing="12">
                            <VBox styleClass="pref-card">
                                <HBox alignment="CENTER_LEFT" spacing="14">
                                    <Label styleClass="pref-icon" text="💰"/>
                                    <VBox HBox.hgrow="ALWAYS">
                                        <Label styleClass="pref-title" text="Budget Range (Per Night)"/>
                                        <Label fx:id="budgetLabel" styleClass="pref-value" text="Not set"/>
                                    </VBox>
                                    <Button onAction="#handleEditBudget" styleClass="ghost-btn" text="Edit"/>
                                </HBox>
                            </VBox>
                            <VBox styleClass="pref-card">
                                <HBox alignment="CENTER_LEFT" spacing="14">
                                    <Label styleClass="pref-icon" text="⭐"/>
                                    <VBox HBox.hgrow="ALWAYS">
                                        <Label styleClass="pref-title" text="Travel Priorities"/>
                                        <Label fx:id="prioritiesLabel" styleClass="pref-value" text="Not set"/>
                                    </VBox>
                                    <Button onAction="#handleEditPriorities" styleClass="ghost-btn" text="Edit"/>
                                </HBox>
                            </VBox>
                            <VBox styleClass="pref-card">
                                <HBox alignment="CENTER_LEFT" spacing="14">
                                    <Label styleClass="pref-icon" text="📍"/>
                                    <VBox HBox.hgrow="ALWAYS">
                                        <Label styleClass="pref-title" text="Location Preferences"/>
                                        <Label fx:id="locationLabel" styleClass="pref-value" text="Not set"/>
                                    </VBox>
                                    <Button onAction="#handleEditLocation" styleClass="ghost-btn" text="Edit"/>
                                </HBox>
                            </VBox>
                            <VBox styleClass="pref-card">
                                <HBox alignment="CENTER_LEFT" spacing="14">
                                    <Label styleClass="pref-icon" text="🏨"/>
                                    <VBox HBox.hgrow="ALWAYS">
                                        <Label styleClass="pref-title" text="Accommodation Types"/>
                                        <Label fx:id="accommodationLabel" styleClass="pref-value" text="Not set"/>
                                    </VBox>
                                    <Button onAction="#handleEditAccommodation" styleClass="ghost-btn" text="Edit"/>
                                </HBox>
                            </VBox>
                            <VBox styleClass="pref-card">
                                <HBox alignment="CENTER_LEFT" spacing="14">
                                    <Label styleClass="pref-icon" text="🎨"/>
                                    <VBox HBox.hgrow="ALWAYS">
                                        <Label styleClass="pref-title" text="Travel Style / Themes"/>
                                        <Label fx:id="styleLabel" styleClass="pref-value" text="Not set"/>
                                    </VBox>
                                    <Button onAction="#handleEditStyle" styleClass="ghost-btn" text="Edit"/>
                                </HBox>
                            </VBox>
                            <VBox styleClass="pref-card">
                                <HBox alignment="CENTER_LEFT" spacing="14">
                                    <Label styleClass="pref-icon" text="🍽️"/>
                                    <VBox HBox.hgrow="ALWAYS">
                                        <Label styleClass="pref-title" text="Dietary Restrictions"/>
                                        <Label fx:id="dietaryLabel" styleClass="pref-value" text="Not set"/>
                                    </VBox>
                                    <Button onAction="#handleEditDietary" styleClass="ghost-btn" text="Edit"/>
                                </HBox>
                            </VBox>
                            <VBox styleClass="pref-card">
                                <HBox alignment="CENTER_LEFT" spacing="14">
                                    <Label styleClass="pref-icon" text="🌤️"/>
                                    <VBox HBox.hgrow="ALWAYS">
                                        <Label styleClass="pref-title" text="Preferred Climate"/>
                                        <Label fx:id="climateLabel" styleClass="pref-value" text="Not set"/>
                                    </VBox>
                                    <Button onAction="#handleEditClimate" styleClass="ghost-btn" text="Edit"/>
                                </HBox>
                            </VBox>
                            <VBox styleClass="pref-card">
                                <HBox alignment="CENTER_LEFT" spacing="14">
                                    <Label styleClass="pref-icon" text="⚡"/>
                                    <VBox HBox.hgrow="ALWAYS">
                                        <Label styleClass="pref-title" text="Travel Pace"/>
                                        <Label fx:id="paceLabel" styleClass="pref-value" text="Not set"/>
                                    </VBox>
                                    <Button onAction="#handleEditPace" styleClass="ghost-btn" text="Edit"/>
                                </HBox>
                            </VBox>
                            <VBox styleClass="pref-card">
                                <HBox alignment="CENTER_LEFT" spacing="14">
                                    <Label styleClass="pref-icon" text="👥"/>
                                    <VBox HBox.hgrow="ALWAYS">
                                        <Label styleClass="pref-title" text="Group Type"/>
                                        <Label fx:id="groupLabel" styleClass="pref-value" text="Not set"/>
                                    </VBox>
                                    <Button onAction="#handleEditGroup" styleClass="ghost-btn" text="Edit"/>
                                </HBox>
                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </VBox>

            <!-- VIEW 3: ACCOUNT SECURITY -->
            <VBox fx:id="securityView" spacing="28" visible="false">
                <VBox spacing="4">
                    <Label styleClass="page-title" text="Account Security"/>
                    <Label styleClass="page-subtitle"
                           text="Manage your password, email health, and account data."/>
                </VBox>

                <ScrollPane fitToWidth="true"
                            style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;">
                    <content>
                        <VBox spacing="20">

                            <!-- Change Password -->
                            <VBox spacing="20" styleClass="content-card">
                                <Label styleClass="card-section-title" text="🔑  Change Password"/>
                                <VBox spacing="14">
                                    <VBox spacing="7">
                                        <Label styleClass="input-label" text="Current Password"/>
                                        <PasswordField fx:id="currentPasswordField"
                                                       promptText="Enter current password"
                                                       styleClass="modern-input"/>
                                        <Label fx:id="currentPasswordError"
                                               styleClass="error-label" visible="false"/>
                                    </VBox>
                                    <VBox spacing="7">
                                        <Label styleClass="input-label" text="New Password"/>
                                        <PasswordField fx:id="newPasswordField"
                                                       promptText="Min 8 chars · uppercase · number"
                                                       styleClass="modern-input"/>
                                        <Label fx:id="newPasswordError" styleClass="error-label"
                                               visible="false"/>
                                    </VBox>
                                    <VBox spacing="7">
                                        <Label styleClass="input-label" text="Confirm New Password"/>
                                        <PasswordField fx:id="confirmPasswordField"
                                                       promptText="Re-enter new password"
                                                       styleClass="modern-input"/>
                                        <Label fx:id="confirmPasswordError"
                                               styleClass="error-label" visible="false"/>
                                    </VBox>
                                    <HBox alignment="CENTER_RIGHT" style="-fx-padding: 8 0 0 0;">
                                        <Label fx:id="passwordStatusLabel"
                                               style="-fx-padding: 0 18 0 0;" visible="false"/>
                                        <Button onAction="#handleChangePassword"
                                                styleClass="primary-btn" text="Change Password"/>
                                    </HBox>
                                </VBox>
                            </VBox>

                            <!-- Email Security -->
                            <VBox spacing="14" styleClass="content-card">
                                <Label styleClass="card-section-title" text="📧  Email Security Check"/>
                                <Label styleClass="card-section-hint"
                                       text="Verify your email's validity, data breach history, quality score, and whether it's a disposable address."
                                       wrapText="true"/>
                                <HBox>
                                    <Button fx:id="checkEmailBtn"
                                            onAction="#handleCheckEmailReputation"
                                            styleClass="teal-btn"
                                            text="🔍  Check Email Reputation"/>
                                </HBox>
                            </VBox>

                            <!-- Danger Zone -->
                            <VBox spacing="14" styleClass="danger-card">
                                <Label styleClass="danger-title" text="⚠️  Danger Zone"/>
                                <Label styleClass="card-section-hint"
                                       text="Once you delete your account, all your data will be permanently removed. This cannot be undone."
                                       wrapText="true"/>
                                <HBox>
                                    <Button onAction="#handleDeleteAccount"
                                            styleClass="delete-button"
                                            text="Delete My Account"/>
                                </HBox>
                            </VBox>

                        </VBox>
                    </content>
                </ScrollPane>
            </VBox>

        </StackPane>
    </HBox>

</AnchorPane>
