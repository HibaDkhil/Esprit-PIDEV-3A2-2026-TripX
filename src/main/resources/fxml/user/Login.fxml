<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.controllers.user.LoginController"
           style="-fx-background-color: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">

    <VBox alignment="CENTER" spacing="24" maxWidth="400">
        
        <!-- Login Form -->
        <VBox spacing="16" style="-fx-background-color: white; -fx-background-radius: 20; -fx-padding: 40; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 30, 0, 0, 10);">
            
            <Label text="Welcome Back" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2D3748;"/>
            <Label text="Sign in to continue" style="-fx-font-size: 13px; -fx-text-fill: #718096;"/>
            
            <VBox spacing="8">
                <Label text="Username" style="-fx-font-weight: 600; -fx-text-fill: #4A5568;"/>
                <TextField fx:id="txtUsername" promptText="Enter your username"
                           style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px;"/>
            </VBox>
            
            <VBox spacing="8">
                <Label text="Password" style="-fx-font-weight: 600; -fx-text-fill: #4A5568;"/>
                <PasswordField fx:id="txtPassword" promptText="Enter your password"
                               style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 14px;"/>
            </VBox>
            
            <Label fx:id="lblError" text="" wrapText="true" 
                   style="-fx-text-fill: #E53E3E; -fx-font-size: 12px;" visible="false" managed="false"/>
            
            <Button fx:id="btnLogin" text="Sign In" maxWidth="Infinity" defaultButton="true"
                    style="-fx-background-color: linear-gradient(to right, #667eea, #764ba2); -fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 14; -fx-cursor: hand;"/>
            
            <Separator style="-fx-padding: 8 0;"/>
            
            <HBox alignment="CENTER" spacing="8">
                <Label text="Don't have an account?" style="-fx-text-fill: #718096; -fx-font-size: 13px;"/>
                <Hyperlink fx:id="linkSignup" text="Sign Up" style="-fx-text-fill: #667eea; -fx-font-weight: 600; -fx-font-size: 13px;"/>
            </HBox>
        </VBox>
        
    </VBox>

</StackPane>
