<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #f4f4f4;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.user.ForgotPasswordController">
    <children>
        <VBox alignment="CENTER" spacing="30.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #333;" text="Reset Password" />
                
                <StackPane>
                    <children>
                        <!-- Step 1: Email -->
                        <VBox fx:id="stepEmail" alignment="CENTER" spacing="20.0" maxWidth="400.0">
                            <children>
                                <Label text="Enter your account email to receive a verification code" textAlignment="CENTER" wrapText="true" />
                                <TextField fx:id="emailField" prefHeight="45.0" promptText="Email Address" style="-fx-background-radius: 10;" />
                                <Label fx:id="emailError" style="-fx-text-fill: red;" />
                                <Button onAction="#handleSendCode" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25;" text="Send Code" />
                            </children>
                        </VBox>
                        
                        <!-- Step 2: Code -->
                        <VBox fx:id="stepCode" alignment="CENTER" spacing="20.0" maxWidth="400.0" visible="false">
                            <children>
                                <Label text="Enter the 6-digit code sent to your email" textAlignment="CENTER" wrapText="true" />
                                <TextField fx:id="codeField" alignment="CENTER" prefHeight="45.0" promptText="Enter Code" style="-fx-background-radius: 10; -fx-font-size: 18px; -fx-letter-spacing: 5;" />
                                <Label fx:id="codeError" style="-fx-text-fill: red;" />
                                <Button onAction="#handleVerifyCode" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25;" text="Verify Code" />
                            </children>
                        </VBox>
                        
                        <!-- Step 3: New Password -->
                        <VBox fx:id="stepNewPassword" alignment="CENTER" spacing="20.0" maxWidth="400.0" visible="false">
                            <children>
                                <Label text="Create a new secure password" textAlignment="CENTER" wrapText="true" />
                                <PasswordField fx:id="newPasswordField" prefHeight="45.0" promptText="New Password" style="-fx-background-radius: 10;" />
                                <PasswordField fx:id="confirmPasswordField" prefHeight="45.0" promptText="Confirm Password" style="-fx-background-radius: 10;" />
                                <Label fx:id="passwordError" style="-fx-text-fill: red;" wrapText="true" />
                                <Button onAction="#handleResetPassword" prefHeight="45.0" prefWidth="200.0" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 25;" text="Reset Password" />
                            </children>
                        </VBox>
                    </children>
                </StackPane>
                
                <Hyperlink onAction="#handleBackToLogin" text="Back to Login" textFill="#2196f3" />
            </children>
            <padding>
                <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
            </padding>
        </VBox>
    </children>
</AnchorPane>
