<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="800.0" prefWidth="1100.0"
            styleClass="blog-management-root"
            style="-fx-background-color: #F5F7FA;"
            stylesheets="@../../css/blog-admin.css"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.admin.BlogManagementController">

    <VBox spacing="24"
          AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0"
          AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0"
          style="-fx-background-color: #F5F7FA;">
        <padding>
            <Insets top="17" right="32" bottom="32" left="32"/>
        </padding>

        <!-- ============ HEADER (same as Packs/Offers) ============ -->
        <HBox alignment="CENTER_LEFT" spacing="24">
            <VBox spacing="8" HBox.hgrow="ALWAYS">
                <Label text="📝 Blog &amp; Community"
                       style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #1A202C;"/>
                <Label text="Manage posts, travel stories, comments, stories, reports and community"
                       style="-fx-font-size: 14px; -fx-text-fill: #718096;"/>
            </VBox>
        </HBox>

        <!-- ============ STATS ROW (gradient cards like Packs) ============ -->
        <HBox spacing="25">
            <VBox spacing="5" style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-background-radius: 16; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4);" HBox.hgrow="ALWAYS">
                <Label text="📄" style="-fx-font-size: 32px;"/>
                <Label fx:id="postsCountLabel" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Posts" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-weight: 600;"/>
            </VBox>
            <VBox spacing="5" style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-background-radius: 16; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4);" HBox.hgrow="ALWAYS">
                <Label text="✈️" style="-fx-font-size: 32px;"/>
                <Label fx:id="storiesCountLabel" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Travel Stories" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-weight: 600;"/>
            </VBox>
            <VBox spacing="5" style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-background-radius: 16; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4);" HBox.hgrow="ALWAYS">
                <Label text="💬" style="-fx-font-size: 32px;"/>
                <Label fx:id="commentsCountLabel" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Comments" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-weight: 600;"/>
            </VBox>
            <VBox spacing="5" style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-background-radius: 16; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4);" HBox.hgrow="ALWAYS">
                <Label text="📸" style="-fx-font-size: 32px;"/>
                <Label fx:id="igStoriesCountLabel" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Active Stories" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-weight: 600;"/>
            </VBox>
            <VBox spacing="5" style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-background-radius: 16; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4);" HBox.hgrow="ALWAYS">
                <Label text="👥" style="-fx-font-size: 32px;"/>
                <Label fx:id="followsCountLabel" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Follows" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-weight: 600;"/>
            </VBox>
        </HBox>

        <!-- ============ MAIN TABS (same style as Packs content area) ============ -->
        <TabPane fx:id="mainTabPane" VBox.vgrow="ALWAYS"
                 style="-fx-background-color: white; -fx-background-radius: 16;
                        -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 2);">

            <!-- ====== POSTS TAB ====== -->
            <Tab text="📄 Posts" closable="false">
                <VBox spacing="14" style="-fx-padding: 20;">
                    <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-background-color: #F7FAFC; -fx-background-radius: 10; -fx-padding: 12;">
                        <Label text="🔍" style="-fx-font-size: 20px;"/>
                        <TextField fx:id="postSearchField"
                                   promptText="Search by title, content or type..."
                                   prefHeight="38" prefWidth="300"
                                   style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 13px;"
                                   HBox.hgrow="ALWAYS"/>
                        <Button fx:id="postSearchBtn" text="Search"
                                style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand;"/>
                        <Button fx:id="addPostBtn" text="+ Add Post"
                                style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand;"/>
                        <Button fx:id="refreshPostsBtn" text="⟳ Refresh"
                                style="-fx-background-color: #EDF2F7; -fx-text-fill: #4A5568; -fx-font-weight: 600; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand;"/>
                    </HBox>
                    <TableView fx:id="postsTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12;">
                        <columns>
                            <TableColumn fx:id="postIdCol"        text="ID"        prefWidth="55"/>
                            <TableColumn fx:id="postUserIdCol"    text="User ID"   prefWidth="70"/>
                            <TableColumn fx:id="postTitleCol"     text="Title"     prefWidth="180"/>
                            <TableColumn fx:id="postBodyCol"      text="Content"   prefWidth="220"/>
                            <TableColumn fx:id="postTypeCol"      text="Type"      prefWidth="90"/>
                            <TableColumn fx:id="postConfirmedCol" text="Approved"  prefWidth="80"/>
                            <TableColumn fx:id="postActionsCol"   text="Actions"   prefWidth="200"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

            <!-- ====== TRAVEL STORIES TAB ====== -->
            <Tab text="✈️ Travel Stories" closable="false">
                <VBox spacing="14" style="-fx-padding: 20;">
                    <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-background-color: #F7FAFC; -fx-background-radius: 10; -fx-padding: 12;">
                        <Label text="🔍" style="-fx-font-size: 20px;"/>
                        <TextField fx:id="storySearchField"
                                   promptText="Search by title, destination or summary..."
                                   prefHeight="38" prefWidth="300"
                                   style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 13px;"
                                   HBox.hgrow="ALWAYS"/>
                        <Button fx:id="storySearchBtn" text="Search"
                                style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand;"/>
                        <Button fx:id="addStoryBtn" text="+ Add Story"
                                style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand;"/>
                        <Button fx:id="refreshStoriesBtn" text="⟳ Refresh"
                                style="-fx-background-color: #EDF2F7; -fx-text-fill: #4A5568; -fx-font-weight: 600; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand;"/>
                    </HBox>
                    <TableView fx:id="storiesTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12;">
                        <columns>
                            <TableColumn fx:id="storyIdCol"          text="ID"          prefWidth="55"/>
                            <TableColumn fx:id="storyUserIdCol"      text="User ID"     prefWidth="70"/>
                            <TableColumn fx:id="storyTitleCol"       text="Title"       prefWidth="160"/>
                            <TableColumn fx:id="storyDestinationCol" text="Destination" prefWidth="130"/>
                            <TableColumn fx:id="storySummaryCol"     text="Summary"     prefWidth="200"/>
                            <TableColumn fx:id="storyRatingCol"      text="Rating"      prefWidth="70"/>
                            <TableColumn fx:id="storyActionsCol"     text="Actions"     prefWidth="200"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

            <!-- ====== COMMENTS TAB ====== -->
            <Tab text="💬 Comments" closable="false">
                <VBox spacing="14" style="-fx-padding: 20;">
                    <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-background-color: #F7FAFC; -fx-background-radius: 10; -fx-padding: 12;">
                        <Label text="🔍" style="-fx-font-size: 20px;"/>
                        <TextField fx:id="commentSearchField"
                                   promptText="Search by content..."
                                   prefHeight="38" prefWidth="300"
                                   style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 13px;"
                                   HBox.hgrow="ALWAYS"/>
                        <Button fx:id="commentSearchBtn" text="Search"
                                style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand;"/>
                        <Button fx:id="refreshCommentsBtn" text="⟳ Refresh"
                                style="-fx-background-color: #EDF2F7; -fx-text-fill: #4A5568; -fx-font-weight: 600; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand;"/>
                    </HBox>
                    <TableView fx:id="commentsTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12;">
                        <columns>
                            <TableColumn fx:id="commentIdCol"      text="ID"       prefWidth="55"/>
                            <TableColumn fx:id="commentUserIdCol"  text="User ID"  prefWidth="70"/>
                            <TableColumn fx:id="commentPostIdCol"  text="Post ID"  prefWidth="70"/>
                            <TableColumn fx:id="commentStoryIdCol" text="Story ID" prefWidth="75"/>
                            <TableColumn fx:id="commentBodyCol"    text="Content"  prefWidth="300"/>
                            <TableColumn fx:id="commentActionsCol" text="Actions"  prefWidth="180"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

            <!-- ====== INSTAGRAM STORIES TAB ====== -->
            <Tab text="📸 Stories" closable="false">
                <VBox spacing="14" style="-fx-padding: 20;">
                    <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-background-color: #F7FAFC; -fx-background-radius: 10; -fx-padding: 12;">
                        <Label text="🔍" style="-fx-font-size: 20px;"/>
                        <TextField fx:id="igStorySearchField"
                                   promptText="Search by caption or user ID..."
                                   prefHeight="38" prefWidth="300"
                                   style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 13px;"
                                   HBox.hgrow="ALWAYS"/>
                        <Button fx:id="cleanExpiredStoriesBtn" text="🗑 Clean Expired"
                                style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand;"/>
                        <Button fx:id="refreshIgStoriesBtn" text="⟳ Refresh"
                                style="-fx-background-color: #EDF2F7; -fx-text-fill: #4A5568; -fx-font-weight: 600; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand;"/>
                    </HBox>
                    <Label text="Only active (non-expired) stories are shown."
                           style="-fx-font-size: 12px; -fx-text-fill: #718096;"/>
                    <TableView fx:id="igStoriesTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12;">
                        <columns>
                            <TableColumn fx:id="igStoryIdCol"        text="ID"        prefWidth="60"/>
                            <TableColumn fx:id="igStoryUserIdCol"    text="User ID"   prefWidth="80"/>
                            <TableColumn fx:id="igStoryCaptionCol"   text="Caption"   prefWidth="220"/>
                            <TableColumn fx:id="igStoryCreatedCol"   text="Created"   prefWidth="150"/>
                            <TableColumn fx:id="igStoryExpiresCol"   text="Expires"   prefWidth="150"/>
                            <TableColumn fx:id="igStoryActionsCol"   text="Actions"   prefWidth="150"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

            <!-- ====== FOLLOWINGS TAB ====== -->
            <Tab text="👥 Follows" closable="false">
                <VBox spacing="14" style="-fx-padding: 20;">
                    <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-background-color: #F7FAFC; -fx-background-radius: 10; -fx-padding: 12;">
                        <Label text="🔍" style="-fx-font-size: 20px;"/>
                        <TextField fx:id="followSearchField"
                                   promptText="Search by follower/followed ID..."
                                   prefHeight="38" prefWidth="300"
                                   style="-fx-background-color: white; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 13px;"
                                   HBox.hgrow="ALWAYS"/>
                        <Button fx:id="refreshFollowsBtn" text="⟳ Refresh"
                                style="-fx-background-color: #EDF2F7; -fx-text-fill: #4A5568; -fx-font-weight: 600; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand;"/>
                        <Button fx:id="refreshStatsBtn" text="📊 Refresh Stats"
                                style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand;"/>
                    </HBox>
                    <TableView fx:id="followingsTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E2E8F0; -fx-border-radius: 12;">
                        <columns>
                            <TableColumn fx:id="followIdCol"         text="ID"          prefWidth="60"/>
                            <TableColumn fx:id="followerIdCol"       text="Follower ID" prefWidth="100"/>
                            <TableColumn fx:id="followerNameCol"     text="Follower"    prefWidth="160"/>
                            <TableColumn fx:id="followedIdCol"       text="Followed ID" prefWidth="100"/>
                            <TableColumn fx:id="followedNameCol"     text="Followed"    prefWidth="160"/>
                            <TableColumn fx:id="followCreatedCol"    text="Since"       prefWidth="150"/>
                            <TableColumn fx:id="followActionsCol"    text="Actions"     prefWidth="120"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

            <!-- ====== COMMUNITY STATS TAB ====== -->
            <Tab text="📊 Stats" closable="false">
                <VBox spacing="14" style="-fx-padding: 20;">
                    <HBox spacing="14" alignment="CENTER_LEFT">
                        <Label text="Community Statistics — Top contributors by engagement"
                               style="-fx-font-size: 13px; -fx-text-fill: #374151; -fx-font-weight: 700;"/>
                        <HBox.margin><Insets right="8"/></HBox.margin>
                        <Button fx:id="rebuildAllStatsBtn" text="🔄 Rebuild All Stats"
                                style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 7 14;"/>
                        <Button fx:id="refreshStatsTableBtn" text="⟳ Refresh Table"
                                style="-fx-background-color: #e2e8f0; -fx-text-fill: #334155; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 7 14;"/>
                    </HBox>
                    <TableView fx:id="statsTable" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: white; -fx-background-radius: 10;">
                        <columns>
                            <TableColumn fx:id="statsUserIdCol"      text="User ID"     prefWidth="100"/>
                            <TableColumn fx:id="statsPostsCol"       text="Posts"       prefWidth="100"/>
                            <TableColumn fx:id="statsCommentsCol"    text="Comments"    prefWidth="100"/>
                            <TableColumn fx:id="statsReactionsCol"   text="Reactions"   prefWidth="100"/>
                            <TableColumn fx:id="statsFollowersCol"   text="Followers"   prefWidth="100"/>
                        </columns>
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

        </TabPane>
    </VBox>
</AnchorPane>
