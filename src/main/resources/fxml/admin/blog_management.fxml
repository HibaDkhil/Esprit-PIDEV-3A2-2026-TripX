<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="740.0" prefWidth="1040.0" style="-fx-background-color: #F4F6FA;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.admin.BlogManagementController">

    <VBox spacing="20" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0" style="-fx-padding: 30;">

        <Label text="📝 Blog &amp; Social Media" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-font-family: 'Poppins'; -fx-text-fill: #2c3e50;">
            <VBox.margin><Insets bottom="10" /></VBox.margin>
        </Label>
        <Label text="Manage posts, travel stories and comments" style="-fx-font-size: 14px; -fx-font-family: 'Poppins'; -fx-text-fill: #7f8c8d;">
            <VBox.margin><Insets bottom="20" /></VBox.margin>
        </Label>

        <TabPane fx:id="mainTabPane" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
            <!-- POSTS TAB -->
            <Tab text="📄 Posts">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <HBox spacing="10" style="-fx-background-color: #f8f9fa; -fx-background-radius: 10; -fx-padding: 5;" HBox.hgrow="ALWAYS">
                            <Label text="🔍" style="-fx-font-size: 18px; -fx-padding: 5 0 5 10;" />
                            <TextField fx:id="postSearchField" promptText="Search by title or content..." prefHeight="40" style="-fx-background-color: transparent; -fx-font-size: 14px; -fx-font-family: 'Poppins';" HBox.hgrow="ALWAYS" />
                            <Button fx:id="postSearchBtn" text="Search" style="-fx-background-color: #4cccad; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20;" />
                        </HBox>
                        <Button fx:id="addPostBtn" text="+ Add Post" style="-fx-background-color: #4cccad; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 8 20;" />
                    </HBox>
                    <TableView fx:id="postsTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10;">
                        <columns>
                            <TableColumn fx:id="postIdCol" text="ID" prefWidth="60" />
                            <TableColumn fx:id="postUserIdCol" text="User ID" prefWidth="70" />
                            <TableColumn fx:id="postTitleCol" text="Title" prefWidth="180" />
                            <TableColumn fx:id="postBodyCol" text="Content" prefWidth="220" />
                            <TableColumn fx:id="postTypeCol" text="Type" prefWidth="80" />
                            <TableColumn fx:id="postConfirmedCol" text="Confirmed" prefWidth="80" />
                            <TableColumn fx:id="postActionsCol" text="Actions" prefWidth="180" />
                        </columns>
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

            <!-- TRAVEL STORIES TAB -->
            <Tab text="✈️ Travel Stories">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <HBox spacing="10" style="-fx-background-color: #f8f9fa; -fx-background-radius: 10; -fx-padding: 5;" HBox.hgrow="ALWAYS">
                            <Label text="🔍" style="-fx-font-size: 18px; -fx-padding: 5 0 5 10;" />
                            <TextField fx:id="storySearchField" promptText="Search by title, destination..." prefHeight="40" style="-fx-background-color: transparent; -fx-font-size: 14px; -fx-font-family: 'Poppins';" HBox.hgrow="ALWAYS" />
                            <Button fx:id="storySearchBtn" text="Search" style="-fx-background-color: #4cccad; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20;" />
                        </HBox>
                        <Button fx:id="addStoryBtn" text="+ Add Story" style="-fx-background-color: #4cccad; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 8 20;" />
                    </HBox>
                    <TableView fx:id="storiesTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10;">
                        <columns>
                            <TableColumn fx:id="storyIdCol" text="ID" prefWidth="60" />
                            <TableColumn fx:id="storyUserIdCol" text="User ID" prefWidth="70" />
                            <TableColumn fx:id="storyTitleCol" text="Title" prefWidth="160" />
                            <TableColumn fx:id="storyDestinationCol" text="Destination" prefWidth="120" />
                            <TableColumn fx:id="storyContentCol" text="Content" prefWidth="200" />
                            <TableColumn fx:id="storyActionsCol" text="Actions" prefWidth="180" />
                        </columns>
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>

            <!-- COMMENTS TAB -->
            <Tab text="💬 Comments">
                <VBox spacing="15" style="-fx-padding: 20;">
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <HBox spacing="10" style="-fx-background-color: #f8f9fa; -fx-background-radius: 10; -fx-padding: 5;" HBox.hgrow="ALWAYS">
                            <Label text="🔍" style="-fx-font-size: 18px; -fx-padding: 5 0 5 10;" />
                            <TextField fx:id="commentSearchField" promptText="Search by content..." prefHeight="40" style="-fx-background-color: transparent; -fx-font-size: 14px; -fx-font-family: 'Poppins';" HBox.hgrow="ALWAYS" />
                            <Button fx:id="commentSearchBtn" text="Search" style="-fx-background-color: #4cccad; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20;" />
                        </HBox>
                    </HBox>
                    <TableView fx:id="commentsTable" VBox.vgrow="ALWAYS" style="-fx-background-color: white; -fx-background-radius: 10;">
                        <columns>
                            <TableColumn fx:id="commentIdCol" text="ID" prefWidth="60" />
                            <TableColumn fx:id="commentUserIdCol" text="User ID" prefWidth="70" />
                            <TableColumn fx:id="commentPostIdCol" text="Post ID" prefWidth="70" />
                            <TableColumn fx:id="commentStoryIdCol" text="Story ID" prefWidth="80" />
                            <TableColumn fx:id="commentBodyCol" text="Content" prefWidth="280" />
                            <TableColumn fx:id="commentActionsCol" text="Actions" prefWidth="160" />
                        </columns>
                        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                    </TableView>
                </VBox>
            </Tab>
        </TabPane>

        <!-- Stats row (optional) -->
        <HBox spacing="20" alignment="CENTER_LEFT">
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 5, 0, 0, 2);">
                <Circle radius="20" fill="#4cccad" />
                <VBox>
                    <Label text="Posts" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                    <Label fx:id="postsCountLabel" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-font-family: 'Poppins';" />
                </VBox>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 5, 0, 0, 2);">
                <Circle radius="20" fill="#6c63ff" />
                <VBox>
                    <Label text="Travel Stories" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                    <Label fx:id="storiesCountLabel" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-font-family: 'Poppins';" />
                </VBox>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.08), 5, 0, 0, 2);">
                <Circle radius="20" fill="#ffb703" />
                <VBox>
                    <Label text="Comments" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                    <Label fx:id="commentsCountLabel" text="0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-font-family: 'Poppins';" />
                </VBox>
            </HBox>
        </HBox>
    </VBox>
</AnchorPane>