<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.admin.AdminCategoriesController"
      spacing="20" style="-fx-background-color: #F5F7FA;">
    
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label text="Manage Pack Categories" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #063154;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnAddCategory" text="➕ Add Category" 
                style="-fx-background-color: #0A4174; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
    </HBox>

    <!-- Search Bar -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search categories..." 
                   prefWidth="300"
                   style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #E8EAF6; -fx-border-radius: 8; -fx-padding: 10;"/>
    </HBox>

    <!-- Table -->
    <TableView fx:id="categoriesTable" VBox.vgrow="ALWAYS"
               style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E8EAF6; -fx-border-radius: 12;">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="100"/>
            <TableColumn fx:id="colName" text="Category Name" prefWidth="400"/>
            <TableColumn fx:id="colPackCount" text="# Packs" prefWidth="150"/>
            <TableColumn fx:id="colActions" text="Actions" prefWidth="200"/>
        </columns>
    </TableView>

</VBox>
