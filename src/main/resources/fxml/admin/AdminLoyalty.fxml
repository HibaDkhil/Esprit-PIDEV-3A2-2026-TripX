<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.admin.AdminLoyaltyController"
      spacing="20" style="-fx-background-color: #F5F7FA;">
    
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label text="Loyalty Points Overview" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #063154;"/>
        <Region HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Stats Cards -->
    <HBox spacing="16">
        <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E8EAF6; -fx-border-radius: 12; -fx-padding: 20;" HBox.hgrow="ALWAYS">
            <Label text="🥉 Bronze Users" style="-fx-font-size: 14px; -fx-text-fill: #94A3B8; -fx-font-weight: 600;"/>
            <Label fx:id="bronzeCount" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #CD7F32;"/>
        </VBox>
        
        <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E8EAF6; -fx-border-radius: 12; -fx-padding: 20;" HBox.hgrow="ALWAYS">
            <Label text="🥈 Silver Users" style="-fx-font-size: 14px; -fx-text-fill: #94A3B8; -fx-font-weight: 600;"/>
            <Label fx:id="silverCount" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #C0C0C0;"/>
        </VBox>
        
        <VBox spacing="8" style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E8EAF6; -fx-border-radius: 12; -fx-padding: 20;" HBox.hgrow="ALWAYS">
            <Label text="🥇 Gold Users" style="-fx-font-size: 14px; -fx-text-fill: #94A3B8; -fx-font-weight: 600;"/>
            <Label fx:id="goldCount" text="0" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #FFD700;"/>
        </VBox>
    </HBox>

    <!-- Search Bar -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search by username..." 
                   prefWidth="300"
                   style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #E8EAF6; -fx-border-radius: 8; -fx-padding: 10;"/>
        
        <ComboBox fx:id="levelFilter" promptText="Filter by Level" prefWidth="150"
                  style="-fx-background-color: white; -fx-background-radius: 8;"/>
    </HBox>

    <!-- Table -->
    <TableView fx:id="loyaltyTable" VBox.vgrow="ALWAYS"
               style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E8EAF6; -fx-border-radius: 12;">
        <columns>
            <TableColumn fx:id="colUserId" text="User ID" prefWidth="80"/>
            <TableColumn fx:id="colUsername" text="Username" prefWidth="200"/>
            <TableColumn fx:id="colPoints" text="Total Points" prefWidth="120"/>
            <TableColumn fx:id="colLevel" text="Level" prefWidth="120"/>
            <TableColumn fx:id="colDiscount" text="Discount %" prefWidth="100"/>
            <TableColumn fx:id="colLastUpdated" text="Last Updated" prefWidth="180"/>
            <TableColumn fx:id="colActions" text="Actions" prefWidth="150"/>
        </columns>
    </TableView>

</VBox>
